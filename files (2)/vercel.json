{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "env": {
    "REACT_APP_GOOGLE_API_KEY": "@google_api_key",
    "REACT_APP_SHEET_ID": "@sheet_id",
    "REACT_APP_API_BASE_URL": "@api_base_url"
  },
  "regions": [
    "iad1"
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
