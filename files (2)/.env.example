# Google Sheets API Configuration
# ===================================

# 🔑 API Key จาก Google Cloud Console
# ได้มาจาก: https://console.cloud.google.com/apis/credentials
REACT_APP_GOOGLE_API_KEY=YOUR_API_KEY_HERE_REPLACE_THIS

# 📋 Google Sheet ID (Optional)
# ได้มาจาก URL: https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit
# ตัวอย่าง: 1A9c_Qb1K2L3M4N5O6P7Q8R9S0T1U2V3W4
REACT_APP_SHEET_ID=OPTIONAL_SHEET_ID_HERE

# 🌐 API Base URL (สำหรับ future use)
REACT_APP_API_BASE_URL=http://localhost:3000

# 🏫 School Domain (สำหรับ future authentication)
REACT_APP_SCHOOL_DOMAIN=school.ac.th

# 📝 Notes:
# 1. ไฟล์นี้สำหรับการทำงานใน local เท่านั้น
# 2. อย่า commit .env.local ขึ้น GitHub
# 3. ใส่ค่าจริงแล้วเปลี่ยนชื่อเป็น .env.local
# 4. ใน Vercel: ใส่ค่านี้ใน Environment Variables ใหม่
